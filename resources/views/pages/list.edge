<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Raccourcisseur Express</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex flex-col justify-center">

  <nav class="bg-indigo-600 text-white shadow-lg">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center space-x-2">
          <span class="text-2xl font-bold tracking-tight">QR<span class="text-indigo-200">Short</span></span>
        </div>
        
        <div class="flex space-x-6 font-medium">
          <a href="/" class="hover:text-indigo-200 transition">Accueil</a>
          <a href="/list" class="hover:text-indigo-200 transition">Liste</a>
        </div>
      </div>
    </div>
  </nav>

 <div class="max-w-4xl mx-auto py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-bold">Historique des URLs</h1>
    <a href="/" class="text-blue-600 hover:underline">Nouveau lien</a>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full leading-normal">
      <thead>
        <tr class="bg-gray-100 text-gray-600 text-left text-sm uppercase font-bold">
          <th class="px-5 py-3 border-b-2">Original & Court</th>
          <th class="px-5 py-3 border-b-2 text-center">QR</th>
          <th class="px-5 py-3 border-b-2 text-center">Clics</th>
          <th class="px-5 py-3 border-b-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        @if(urls && urls.length)
          @each(url in urls)
          <tr>
            <td class="px-5 py-5 border-b text-sm">
              <p class="text-gray-900 truncate max-w-xs" title="{{ url.originalUrl }}">{{ url.originalUrl }}</p>
              <p class="text-blue-600 font-bold">{{ url.shortUrl }}</p>
              <span class="text-xs text-gray-400 italic">Créé le : {{ url.createdAt }}</span>
            </td>
            <td class="px-5 py-5 border-b text-center">
              <img src="{{ url.qrCodeData }}" width="50" class="inline-block border">
            </td>
            <td class="px-5 py-5 border-b text-center">
              <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-xs font-bold">
                {{ url.clicks }}
              </span>
            </td>
          </tr>
          @endeach
        @else
          <tr>
            <td colspan="4" class="px-5 py-10 border-b text-center text-gray-500 italic">
              Aucun élément dans l'historique.
            </td>
          </tr>
        @endif
      </tbody>
    </table>
  </div>
</div>

<footer class="bg-white border-t py-6 text-center text-gray-500 text-sm">
    <p>&copy; 2025 - Projet Raccourcisseur d'URL & QR Code - Exercice AdonisJS</p>
  </footer>

</body>
</html>