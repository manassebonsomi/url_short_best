<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QR URL Shortener</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  
  <style>
    body {
      background-color: #f3f4f6; /* Fond gris clair */
    }
  </style>
</head>
<body class="min-h-screen flex flex-col justify-center">

<nav class="bg-indigo-600 text-white shadow-lg">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center space-x-2">
          <span class="text-2xl font-bold tracking-tight">QR<span class="text-indigo-200">Short</span></span>
        </div>
        
        <div class="flex space-x-6 font-medium">
          <a href="/" class="hover:text-indigo-200 transition">Accueil</a>
          <a href="/goToUrl" class="hover:text-indigo-200 transition">Liste</a>
        </div>
      </div>
    </div>
  </nav>
  
<div class="max-w-lg mx-auto mt-10 p-6 bg-white rounded-lg shadow border">
  <h2 class="text-2xl font-bold mb-6 text-gray-800">Modifier l'URL</h2>

  <form action="{{ route('UrlController.update', { id: url.id }) }}?_method=PUT" method="POST">
    {{ csrfField() }}
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700">URL complète (destination)</label>
      <input type="url" name="url" value="{{ url.original_url }}" required 
             class="mt-1 w-full border border-gray-300 p-2 rounded focus:ring-blue-500">
    </div>

    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700">URL courte personnalisée (Slug)</label>
      <input type="text" name="short_slug" value="{{ url.slug }}" required 
             class="mt-1 w-full border border-gray-300 p-2 rounded focus:ring-blue-500">
      <p class="text-xs text-gray-500 mt-1 italic">Note: Le QR code sera régénéré si vous changez ce nom.</p>
    </div>

    <div class="flex justify-between items-center">
      <a href="/goToUrl" class="text-gray-600 hover:underline">Annuler</a>
      <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded font-bold hover:bg-indigo-700">
        Enregistrer les modifications
      </button>
    </div>
  </form>
</div>

</body>
</html>